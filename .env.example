# GEMINI_API_KEY: Required for Gemini AI logic.
GEMINI_API_KEY="your_gemini_api_key_here"

# META_API_KEY: For WhatsApp integration (if using Meta APIs).
META_API_KEY="your_meta_api_key_here"

# GOOGLE_SHEET_ID: The master sheet for Nishan Transport.
